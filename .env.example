# AWS S3 (optional — for clip backup/gallery)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=eu-west-3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PUBLIC_BUCKET=your-public-bucket-name

# YouTube cookies (optional — paste Netscape-format cookies to bypass bot detection)
# YOUTUBE_COOKIES=...

# Quality gate: if YouTube offers less than this height, ask the user before
# starting the job instead of silently processing a soft source (0 = off).
# QUALITY_GATE_MIN_HEIGHT=720

# Watermark (optional — defaults shown). A subtle centered overlay is burned
# into every rendered clip so they can't be re-uploaded as someone else's work.
# WATERMARK_TEXT wins over the image; without both, the bundled OpenShorts logo
# is used. Set WATERMARK_ENABLED=0 to turn it off entirely.
# WATERMARK_ENABLED=1
# WATERMARK_TEXT=
# WATERMARK_IMAGE=
# WATERMARK_OPACITY=0.08
# WATERMARK_WIDTH_FRACTION=0.45

# Whisper transcription (optional — defaults shown)
# Model size: tiny/base/small/medium/large-v3. "small" is a good speed/quality
# tradeoff for German; "base" is faster but noticeably worse.
# WHISPER_MODEL=small
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE=int8

# Gemini models (optional — defaults shown). GEMINI_MODEL overrides all tasks
# at once; the task-specific variables override GEMINI_MODEL for that task.
# Pricing per 1M tokens: 3.1-flash-lite $0.25/$1.50 (best value — cheaper AND
# smarter than 2.5-flash), 3-flash-preview $0.50/$3.00, 2.5-flash $0.30/$2.50.
# GEMINI_MODEL=
# GEMINI_MODEL_ANALYSIS=gemini-3.1-flash-lite
# GEMINI_MODEL_EDITOR=gemini-3-flash-preview
# GEMINI_MODEL_THUMBNAIL=gemini-3-flash-preview
# GEMINI_MODEL_IMAGE=gemini-3.1-flash-image-preview
# GEMINI_MODEL_SAAS=gemini-3-flash-preview

# Thinking for the clip-scoring stage (optional). off = model default (cheapest).
# "low"/"high" (Gemini 3 thinking_level) or a token budget number (Gemini 2.5).
# Thinking tokens bill at the OUTPUT rate — enable only if clip choice matters more than cost.
# GEMINI_THINKING_SCORE=off
